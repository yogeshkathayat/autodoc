{
  "name": "autodocai",
  "version": "0.1.0",
  "description": "One-command, AI-driven documentation automation for any git repo",
  "type": "module",
  "license": "MIT",
  "bin": {
    "autodoc": "./bin/docs-gen.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "bin",
    "schema",
    "src/templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "@inquirer/prompts": "^7.5.0",
    "picocolors": "^1.1.1",
    "zod": "^3.24.0",
    "minimatch": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "docs",
    "documentation",
    "ai",
    "claude",
    "automation",
    "git-hooks"
  ]
}
