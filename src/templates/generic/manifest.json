{
  "$schema": "https://unpkg.com/autodocai/schema/manifest.schema.json",
  "version": "1.0",
  "project": "{{PROJECT_NAME}}",
  "framework": "generic",
  "adapter": "claude-code",
  "description": "Auto-generated feature-based documentation manifest",
  "mappings": [
    {
      "id": "architecture-overview",
      "doc": "docs/architecture-overview.md",
      "watches": ["src/**/*", "lib/**/*"],
      "purpose": "High-level project architecture: directory structure, module organization, key abstractions, external dependencies, data flow. Include Mermaid diagrams.",
      "strategy": "rewrite"
    }
  ],
  "ignore": ["**/*.test.*", "**/*.spec.*", "**/node_modules/**", "dist/**", "build/**"]
}
