#!/usr/bin/env sh

# autodoc.ai post-merge hook
# Checks if pulled changes affect documented code and reminds you to update docs.
# This hook is FAST — no AI calls, just glob matching against the manifest.

# Check if hook is disabled
if [ "$(git config --get hooks.skip-autodoc)" = "true" ]; then
  exit 0
fi

# Ensure manifest exists
MANIFEST="docs/_manifest.json"
if [ ! -f "$MANIFEST" ]; then
  exit 0
fi

# Get changed files from the merge
CHANGED=$(git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD 2>/dev/null)
if [ -z "$CHANGED" ]; then
  exit 0
fi

# Quick check: do any changed files match watch patterns in the manifest?
# Use node one-liner for fast glob matching (no external deps)
NEEDS_UPDATE=$(node -e "
const fs = require('fs');
const path = require('path');
try {
  const m = JSON.parse(fs.readFileSync('$MANIFEST', 'utf8'));
  const changed = \`$CHANGED\`.split('\n').filter(Boolean);
  const ignore = (m.ignore || []);
  const hit = m.mappings.some(mapping =>
    mapping.watches.some(pattern => {
      const re = new RegExp(pattern.replace(/\*\*/g, '.*').replace(/\*/g, '[^/]*'));
      return changed.some(f => re.test(f) && !ignore.some(ip => {
        const ir = new RegExp(ip.replace(/\*\*/g, '.*').replace(/\*/g, '[^/]*'));
        return ir.test(f);
      }));
    })
  );
  process.stdout.write(hit ? '1' : '0');
} catch(e) { process.stdout.write('0'); }
" 2>/dev/null)

if [ "$NEEDS_UPDATE" = "1" ]; then
  echo ""
  echo "  📄 autodoc: pulled changes affect documented code."

  # Prompt if running in an interactive terminal
  if [ -t 0 ]; then
    printf "  Update docs now? [y/N] "
    read -r REPLY < /dev/tty 2>/dev/null || REPLY="n"
    case "$REPLY" in
      [yY]|[yY][eE][sS])
        echo ""
        npx autodocai update 2>&1 || echo "  autodoc update failed. Run 'autodoc update' manually."
        ;;
      *)
        echo "  Skipped. Run 'autodoc update' when ready."
        ;;
    esac
  else
    echo "  Run 'autodoc update' to refresh docs."
  fi
  echo ""
fi

exit 0
